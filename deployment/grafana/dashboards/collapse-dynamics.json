{
  "uid": "btc-collapse-dynamics",
  "title": "BTC Miner Supreme — Collapse Dynamics",
  "tags": ["btc", "mining", "collapse"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Blocks Found",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [{ "expr": "btcminer_blocks_found_total", "legendFormat": "blocks" }],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "value": 0, "color": "green" }] } } }
    },
    {
      "id": 2,
      "title": "Rounds Total",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [{ "expr": "btcminer_rounds_total", "legendFormat": "rounds" }]
    },
    {
      "id": 3,
      "title": "Hash Rate",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [{ "expr": "btcminer_hashrate", "legendFormat": "H/s" }],
      "fieldConfig": { "defaults": { "unit": "Hs", "min": 0 } }
    },
    {
      "id": 4,
      "title": "Nonce Success Rate",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [{ "expr": "btcminer_nonce_success_rate", "legendFormat": "rate" }],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 } }
    },
    {
      "id": 5,
      "title": "Round Duration",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        { "expr": "rate(btcminer_round_duration_seconds_sum[1m]) / rate(btcminer_round_duration_seconds_count[1m])", "legendFormat": "avg duration" },
        { "expr": "histogram_quantile(0.99, rate(btcminer_round_duration_seconds_bucket[5m]))", "legendFormat": "p99" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 6,
      "title": "Candidates Per Round",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [{ "expr": "btcminer_candidates_per_round", "legendFormat": "candidates" }],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 7,
      "title": "Entropy Workers",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 12 },
      "targets": [{ "expr": "btcminer_entropy_workers", "legendFormat": "workers" }]
    },
    {
      "id": 8,
      "title": "GPU Utilization",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 12 },
      "targets": [{ "expr": "btcminer_gpu_utilization", "legendFormat": "GPU" }],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "thresholds": { "steps": [{ "value": 0, "color": "green" }, { "value": 0.7, "color": "yellow" }, { "value": 0.9, "color": "red" }] } } }
    },
    {
      "id": 9,
      "title": "FPGA Utilization",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 12 },
      "targets": [{ "expr": "btcminer_fpga_utilization", "legendFormat": "FPGA" }],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "thresholds": { "steps": [{ "value": 0, "color": "green" }, { "value": 0.7, "color": "yellow" }, { "value": 0.9, "color": "red" }] } } }
    },
    {
      "id": 10,
      "title": "System Resources",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 18 },
      "targets": [
        { "expr": "btcminer_cpu_percent", "legendFormat": "CPU %" },
        { "expr": "btcminer_memory_percent", "legendFormat": "Memory %" }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } }
    },
    {
      "id": 11,
      "title": "GAN Replay Buffer & Cone Size",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 18 },
      "targets": [
        { "expr": "btcminer_gan_buffer_size", "legendFormat": "GAN buffer" },
        { "expr": "btcminer_cone_size", "legendFormat": "Cone size" }
      ]
    }
  ]
}
