# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  BTC MINER SUPREME — Environment Variables                             ║
# ║  Copy to .env and fill in real values. NEVER commit .env to git.       ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# ─── Bitcoin Core RPC ─────────────────────────────────────────────────────
BTC_RPC_USER=
BTC_RPC_PASSWORD=

# ─── Stratum Pool ────────────────────────────────────────────────────────
STRATUM_POOL_URL=stratum+tcp://your-pool.com:3333
STRATUM_PASSWORD=

# ─── Cold Wallet ─────────────────────────────────────────────────────────
COLD_WALLET_ADDRESS=

# ─── Grafana ─────────────────────────────────────────────────────────────
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=

# ─── Dashboard API ───────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE=http://localhost:8000

# ─── CORS ────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000
